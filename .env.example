# DataHelp 环境变量配置
# 复制此文件为 .env 后填写

# 默认 provider（不设置则用 mock）
# DATAHELP_PROVIDER=deepseek

# DeepSeek
# DATAHELP_DEEPSEEK_API_KEY=sk-your-key
# DATAHELP_DEEPSEEK_MODEL=deepseek-chat
# DATAHELP_DEEPSEEK_API_BASE=https://api.deepseek.com

# Anthropic Claude
# DATAHELP_ANTHROPIC_API_KEY=sk-ant-your-key
# DATAHELP_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# DATAHELP_ANTHROPIC_API_BASE=https://api.anthropic.com

# OpenAI
# DATAHELP_OPENAI_API_KEY=sk-your-key
# DATAHELP_OPENAI_MODEL=gpt-4o
# DATAHELP_OPENAI_API_BASE=https://api.openai.com/v1

# Ollama（本地模型，不需要 API key）
# DATAHELP_OLLAMA_MODEL=qwen2.5:7b
# DATAHELP_OLLAMA_BASE_URL=http://localhost:11434
